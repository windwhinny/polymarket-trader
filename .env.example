# Polymarket Trader — API Keys
# Copy this file to .env and fill in your keys
# cp .env.example .env

# DeepSeek (default)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Search APIs (pick one)
SERPAPI_API_KEY=your-serpapi-key            # https://serper.dev
TAVILY_API_KEY=tvly-your-tavily-key         # https://tavily.com

# Kimi / Moonshot (OpenAI-compatible)
KIMI_API_KEY=sk-your-kimi-key
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Optional: Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ofox.ai multi-model gateway (Anthropic + OpenAI compatible).
# One key, two endpoints — Claude via /anthropic, OpenAI via /v1.
OFOX_API_KEY=sk-your-ofox-key
OFOX_ANTHROPIC_BASE_URL=https://api.ofox.ai/anthropic
OFOX_OPENAI_BASE_URL=https://api.ofox.ai/v1
