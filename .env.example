# Polymarket Backtest — API Keys
# Copy this file to .env and fill in your keys
# cp .env.example .env

DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
SERPAPI_API_KEY=your-serpapi-key            # https://serper.dev
TAVILY_API_KEY=tvly-your-tavily-key         # https://tavily.com (optional fallback)

# Optional: Anthropic (for --provider anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
